#!/bin/zsh
set -u
set -o pipefail

VERSION="0.1.0"

EXIT_OK=0
EXIT_USAGE=1
EXIT_BLOCKED=2
EXIT_APPLY_FAILED=3

SCRIPT_PATH="$(perl -MCwd=abs_path -e 'print abs_path(shift)' "$0" 2>/dev/null || echo "$0")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"

STATE_DIR="${WALLCTL_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/wallctl}"
BACKUP_DIR="$STATE_DIR/backups"
PID_FILE="$STATE_DIR/watch.pid"
LOG_FILE="$STATE_DIR/watch.log"

POLICY_USER="${WALLCTL_POLICY_USER:-$USER}"
POLICY_PLIST="${WALLCTL_POLICY_PLIST:-/Library/Managed Preferences/$POLICY_USER/com.apple.desktop.plist}"

QUIET=0

log() {
  if [[ "$QUIET" -eq 0 ]]; then
    printf '%s\n' "$*"
  fi
}

err() {
  printf 'wallctl: %s\n' "$*" >&2
}

json_escape() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

require_cmds() {
  local missing=()
  local cmd
  for cmd in "$@"; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
      missing+=("$cmd")
    fi
  done
  if (( ${#missing[@]} > 0 )); then
    err "missing required command(s): ${missing[*]}"
    return 1
  fi
  return 0
}

canonicalize_path() {
  perl -MCwd=abs_path -e 'my $p = shift; my $a = abs_path($p); exit 1 unless defined $a; print $a' "$1" 2>/dev/null
}

image_candidates_from_dir() {
  local dir="$1"
  find "$dir" -type f \
    \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.heic' -o -iname '*.webp' -o -iname '*.tif' -o -iname '*.tiff' \) \
    -print0
}

select_image_from_dir() {
  local dir="$1"
  local picked=""
  local line

  while IFS= read -r -d '' f; do
    local mtime
    mtime="$(stat -f '%m' "$f" 2>/dev/null || true)"
    [[ -z "$mtime" ]] && continue
    printf '%s\t%s\n' "$mtime" "$f"
  done < <(image_candidates_from_dir "$dir") | sort -t $'\t' -k1,1nr -k2,2 | while IFS=$'\t' read -r _ path; do
    printf '%s\n' "$path"
    break
  done
}

validate_image_readable() {
  local p="$1"
  sips -g format "$p" >/dev/null 2>&1
}

resolve_input_image() {
  local input="$1"
  local resolved=""

  if [[ -f "$input" ]]; then
    resolved="$(canonicalize_path "$input")" || return 1
  elif [[ -d "$input" ]]; then
    local selected
    selected="$(select_image_from_dir "$input")"
    if [[ -z "$selected" ]]; then
      err "no supported images found in directory: $input"
      return 1
    fi
    resolved="$(canonicalize_path "$selected")" || return 1
  else
    err "path does not exist: $input"
    return 1
  fi

  if ! validate_image_readable "$resolved"; then
    err "image is not readable by macOS image services: $resolved"
    return 1
  fi

  printf '%s\n' "$resolved"
}

script_set_finder_picture() {
  local img_path="$1"
  local escaped="${img_path//\\/\\\\}"
  escaped="${escaped//\"/\\\"}"
  osascript -e "tell application \"Finder\" to set desktop picture to (POSIX file \"$escaped\" as alias)" >/dev/null
}

script_set_all_desktops() {
  local img_path="$1"
  local escaped="${img_path//\\/\\\\}"
  escaped="${escaped//\"/\\\"}"
  osascript -e "tell application \"System Events\" to tell every desktop to set picture to \"$escaped\"" >/dev/null
}

get_active_path_posix() {
  osascript -e 'tell application "Finder" to get POSIX path of (desktop picture as alias)' 2>/dev/null || true
}

apply_unmanaged_once() {
  local img_path="$1"
  script_set_finder_picture "$img_path" || return 1
  script_set_all_desktops "$img_path" || return 1
  return 0
}

verify_active_matches() {
  local expected="$1"
  local active
  active="$(get_active_path_posix)"
  [[ -n "$active" && "$active" == "$expected" ]]
}

apply_unmanaged_with_verify() {
  local img_path="$1"
  local phase="${2:-normal}"
  WALLCTL_LAST_APPLY_UNVERIFIED=0

  if [[ "${WALLCTL_FORCE_UNMANAGED_FAIL:-0}" == "1" && "$phase" != "managed" ]]; then
    return 1
  fi

  local attempt
  local had_unverifiable=0
  local any_apply_success=0
  for attempt in 1 2; do
    if apply_unmanaged_once "$img_path"; then
      any_apply_success=1
    fi
    sleep 1
    local active
    active="$(get_active_path_posix)"
    if [[ -n "$active" && "$active" == "$img_path" ]]; then
      return 0
    fi
    if [[ -z "$active" ]]; then
      had_unverifiable=1
    fi
  done

  if [[ "$had_unverifiable" -eq 1 && "$any_apply_success" -eq 1 ]]; then
    WALLCTL_LAST_APPLY_UNVERIFIED=1
    return 0
  fi
  return 1
}

managed_state() {
  MANAGED_LOCKED=0
  MANAGED_OVERRIDE_PATH=""
  MANAGED_JAMF_DEFAULT=0

  if [[ ! -f "$POLICY_PLIST" ]]; then
    return 0
  fi

  local locked_raw
  locked_raw="$(plutil -extract locked raw -o - "$POLICY_PLIST" 2>/dev/null || true)"
  local override_raw
  override_raw="$(plutil -extract override-picture-path raw -o - "$POLICY_PLIST" 2>/dev/null || true)"

  if [[ -n "$override_raw" ]]; then
    MANAGED_OVERRIDE_PATH="$override_raw"
  fi

  case "${locked_raw:l}" in
    1|true|yes) MANAGED_LOCKED=1 ;;
    *) MANAGED_LOCKED=0 ;;
  esac

  if [[ -n "$MANAGED_OVERRIDE_PATH" ]]; then
    case "${MANAGED_OVERRIDE_PATH:l}" in
      */jamfconnect/*|*desktopwallpaper-default.*)
        MANAGED_JAMF_DEFAULT=1
        ;;
    esac
  fi
}

target_writable() {
  local target="$1"
  if [[ -e "$target" ]]; then
    [[ -w "$target" ]]
  else
    local parent
    parent="$(dirname "$target")"
    [[ -d "$parent" && -w "$parent" ]]
  fi
}

sudo_cp() {
  local src="$1"
  local dst="$2"
  if sudo -n true >/dev/null 2>&1; then
    sudo -n cp -f "$src" "$dst"
    return $?
  fi
  if [[ -t 0 ]]; then
    sudo cp -f "$src" "$dst"
    return $?
  fi
  err "--sudo-managed-copy requires an interactive terminal (or passwordless sudo)."
  err "run this command directly in Terminal, or omit --sudo-managed-copy if target is writable."
  return 1
}

backup_target() {
  local target="$1"
  local use_sudo="${2:-0}"
  [[ ! -e "$target" ]] && return 0
  mkdir -p "$BACKUP_DIR" || return 1
  local ts
  ts="$(date '+%Y%m%d-%H%M%S')"
  local base
  base="$(basename "$target")"
  local out="$BACKUP_DIR/${ts}-${base}"
  if [[ "$use_sudo" -eq 1 ]]; then
    sudo_cp "$target" "$out" || return 1
  else
    cp -f "$target" "$out" || return 1
  fi
  log "backup created: $out"
}

apply_managed_with_verify() {
  local src="$1"
  local target="$2"
  local use_sudo="${3:-0}"
  local skip_backup="${4:-0}"
  local prepared_src="$src"
  local tmp_dir=""

  # Convert source to match managed target extension when needed (e.g. WEBP -> .jpg target).
  local target_ext src_ext
  target_ext="${target##*.}"
  src_ext="${src##*.}"
  target_ext="${target_ext:l}"
  src_ext="${src_ext:l}"

  if [[ "$target_ext" != "$src_ext" ]]; then
    local tmp_out
    tmp_dir="$(mktemp -d /tmp/wallctl-convert.XXXXXX)"
    case "$target_ext" in
      jpg|jpeg)
        tmp_out="$tmp_dir/converted.jpg"
        if sips -s format jpeg "$src" --out "$tmp_out" >/dev/null 2>&1; then
          prepared_src="$tmp_out"
          log "converted source image to JPEG for managed target"
        else
          rm -rf "$tmp_dir" >/dev/null 2>&1 || true
          err "failed to convert source image to JPEG for managed target"
          return $EXIT_USAGE
        fi
        ;;
      png)
        tmp_out="$tmp_dir/converted.png"
        if sips -s format png "$src" --out "$tmp_out" >/dev/null 2>&1; then
          prepared_src="$tmp_out"
          log "converted source image to PNG for managed target"
        else
          rm -rf "$tmp_dir" >/dev/null 2>&1 || true
          err "failed to convert source image to PNG for managed target"
          return $EXIT_USAGE
        fi
        ;;
    esac
  fi

  if ! target_writable "$target" && [[ "$use_sudo" -ne 1 ]]; then
    err "managed override target is not writable: $target"
    return $EXIT_BLOCKED
  fi

  if [[ "$skip_backup" -eq 0 ]]; then
    backup_target "$target" "$use_sudo" || {
      err "failed to create backup for managed target: $target"
      return $EXIT_BLOCKED
    }
  fi

  if [[ "$use_sudo" -eq 1 ]]; then
    if ! sudo_cp "$prepared_src" "$target"; then
      err "failed to copy source image into managed target with sudo: $target"
      return $EXIT_BLOCKED
    fi
  else
    if ! cp -f "$prepared_src" "$target"; then
      err "failed to copy source image into managed target: $target"
      return $EXIT_BLOCKED
    fi
  fi

  if apply_unmanaged_with_verify "$target" managed; then
    [[ -n "$tmp_dir" ]] && rm -rf "$tmp_dir" >/dev/null 2>&1 || true
    return $EXIT_OK
  fi

  [[ -n "$tmp_dir" ]] && rm -rf "$tmp_dir" >/dev/null 2>&1 || true
  err "managed fallback applied but wallpaper verification still failed"
  return $EXIT_APPLY_FAILED
}

ensure_state_dir() {
  mkdir -p "$STATE_DIR" "$BACKUP_DIR"
}

latest_backup_path() {
  [[ -d "$BACKUP_DIR" ]] || return 1
  local latest
  latest="$(
    find "$BACKUP_DIR" -maxdepth 1 -type f -print0 2>/dev/null | while IFS= read -r -d '' f; do
      printf '%s\t%s\n' "$(stat -f '%m' "$f" 2>/dev/null || echo 0)" "$f"
    done | sort -t $'\t' -k1,1nr -k2,2 | head -n 1 | cut -f2-
  )"
  [[ -n "$latest" ]] || return 1
  printf '%s\n' "$latest"
}

watch_running_pid() {
  if [[ -f "$PID_FILE" ]]; then
    local pid
    pid="$(cat "$PID_FILE" 2>/dev/null || true)"
    if [[ -n "$pid" ]] && kill -0 "$pid" >/dev/null 2>&1; then
      printf '%s\n' "$pid"
      return 0
    fi
  fi
  return 1
}

start_watch_background() {
  local input="$1"
  local interval="$2"
  if ! ensure_state_dir; then
    err "cannot create state directory: $STATE_DIR"
    return $EXIT_BLOCKED
  fi

  local existing
  if existing="$(watch_running_pid)"; then
    err "watch is already running (pid $existing). Stop it first with: wallctl stop-watch"
    return $EXIT_USAGE
  fi

  nohup zsh "$SCRIPT_PATH" watch "$input" --interval "$interval" --quiet >>"$LOG_FILE" 2>&1 &
  local pid=$!
  sleep 1
  if ! kill -0 "$pid" >/dev/null 2>&1; then
    err "watch process failed to start; check log: $LOG_FILE"
    return $EXIT_BLOCKED
  fi
  if ! printf '%s\n' "$pid" > "$PID_FILE"; then
    err "failed to write watch pid file: $PID_FILE"
    kill "$pid" >/dev/null 2>&1 || true
    return $EXIT_BLOCKED
  fi
  log "watch started in background (pid $pid)"
  log "watch log: $LOG_FILE"
  return $EXIT_OK
}

stop_watch() {
  local stopped=0
  if [[ -f "$PID_FILE" ]]; then
    local pid
    pid="$(cat "$PID_FILE" 2>/dev/null || true)"
    if [[ -n "$pid" ]] && kill -0 "$pid" >/dev/null 2>&1; then
      kill "$pid" >/dev/null 2>&1 || true
      sleep 1
      if kill -0 "$pid" >/dev/null 2>&1; then
        kill -9 "$pid" >/dev/null 2>&1 || true
      fi
      stopped=1
    fi
    rm -f "$PID_FILE"
  fi

  # Fallback for stale/no pid file.
  pkill -f "${SCRIPT_PATH} watch" >/dev/null 2>&1 || true

  if [[ "$stopped" -eq 1 ]]; then
    log "watch stopped"
  else
    log "no active watch process found"
  fi

  return $EXIT_OK
}

print_help() {
  cat <<'HELP'
wallctl - Portable macOS wallpaper CLI

Usage:
  wallctl
  wallctl set <file_or_dir> [--watch] [--interval N] [--quiet] [--force-refresh] [--sudo-managed-copy] [--force-managed-target]
  wallctl watch <file_or_dir> [--interval N] [--quiet]
  wallctl verify [--json]
  wallctl doctor [--json]
  wallctl restore [--latest | --path <backup_path>] [--quiet]
  wallctl stop-watch
  wallctl version
  wallctl help

Exit codes:
  0 success
  1 usage/input error
  2 permission/policy blocked
  3 apply attempted but verification failed
HELP
}

cmd_interactive() {
  local input=""
  local rc=0

  if [[ -t 0 ]]; then
    printf 'Enter image file or directory path: '
  fi

  IFS= read -r input
  input="${input#"${input%%[![:space:]]*}"}"
  input="${input%"${input##*[![:space:]]}"}"
  if [[ -z "$input" ]]; then
    err "no path provided"
    return $EXIT_USAGE
  fi

  cmd_set "$input" --force-refresh
  rc=$?
  if [[ "$rc" -eq 0 ]]; then
    return 0
  fi

  managed_state
  if [[ "$rc" -eq "$EXIT_BLOCKED" && "$MANAGED_LOCKED" -eq 1 && -n "$MANAGED_OVERRIDE_PATH" ]]; then
    if [[ ! -t 0 ]]; then
      err "managed policy blocked this non-interactive run; rerun in Terminal to allow sudo-managed retry"
      return $rc
    fi
    printf 'Managed policy detected. Retry with sudo-managed copy? [Y/n]: '
    local ans
    IFS= read -r ans
    case "${ans:l}" in
      ""|y|yes)
        cmd_set "$input" --force-refresh --force-managed-target --sudo-managed-copy
        return $?
        ;;
      *)
        return $rc
        ;;
    esac
  fi

  return $rc
}

refresh_wallpaper_services() {
  rm -rf "$HOME/Library/Application Support/com.apple.wallpaper/Store"/* >/dev/null 2>&1 || true
  killall WallpaperAgent >/dev/null 2>&1 || true
  killall Dock >/dev/null 2>&1 || true
  sleep 1
}

stabilize_apply() {
  local target="$1"
  local attempts="${2:-2}"
  local i
  for (( i=1; i<=attempts; i++ )); do
    sleep 2
    apply_unmanaged_once "$target" >/dev/null 2>&1 || true
    sleep 1
    local active
    active="$(get_active_path_posix)"
    if [[ -n "$active" && "$active" == "$target" ]]; then
      return 0
    fi
  done
  return 0
}

jamf_second_pass() {
  local src="$1"
  local target="$2"
  local use_sudo="${3:-0}"

  # Jamf-managed desktops can require a delayed second commit to visually take effect.
  sleep 6
  refresh_wallpaper_services
  apply_managed_with_verify "$src" "$target" "$use_sudo" 1 >/dev/null 2>&1 || true
  apply_unmanaged_once "$target" >/dev/null 2>&1 || true
  sleep 1
}

cmd_set() {
  local input=""
  local watch=0
  local interval="15"
  local force_refresh=0
  local sudo_managed_copy=0
  local force_managed_target=0

  while (( $# > 0 )); do
    case "$1" in
      --watch) watch=1 ;;
      --force-refresh) force_refresh=1 ;;
      --sudo-managed-copy) sudo_managed_copy=1 ;;
      --force-managed-target) force_managed_target=1 ;;
      --interval)
        shift
        [[ $# -gt 0 ]] || { err "--interval requires a value"; return $EXIT_USAGE; }
        interval="$1"
        ;;
      --quiet) QUIET=1 ;;
      -h|--help)
        print_help
        return $EXIT_OK
        ;;
      --*) err "unknown option: $1"; return $EXIT_USAGE ;;
      *)
        if [[ -z "$input" ]]; then
          input="$1"
        else
          err "unexpected extra argument: $1"
          return $EXIT_USAGE
        fi
        ;;
    esac
    shift
  done

  [[ -n "$input" ]] || { err "set requires <file_or_dir>"; return $EXIT_USAGE; }
  [[ "$interval" =~ '^[0-9]+$' ]] || { err "interval must be a whole number"; return $EXIT_USAGE; }

  require_cmds osascript sips plutil shasum || return $EXIT_BLOCKED

  local src
  src="$(resolve_input_image "$input")" || return $EXIT_USAGE
  log "resolved image: $src"

  managed_state

  if [[ "$force_managed_target" -eq 0 && "$MANAGED_LOCKED" -eq 1 && "$MANAGED_JAMF_DEFAULT" -eq 1 ]]; then
    force_managed_target=1
    log "jamf-managed wallpaper policy detected; using managed override target automatically"
  fi

  if [[ "$force_refresh" -eq 1 ]]; then
    refresh_wallpaper_services
  fi

  if [[ "$force_managed_target" -eq 1 ]]; then
    if [[ "$MANAGED_LOCKED" -ne 1 || -z "$MANAGED_OVERRIDE_PATH" ]]; then
      err "--force-managed-target requested, but no managed override path was detected"
      return $EXIT_BLOCKED
    fi
    local forced_rc
    apply_managed_with_verify "$src" "$MANAGED_OVERRIDE_PATH" "$sudo_managed_copy"
    forced_rc=$?
    if [[ "$forced_rc" -ne 0 ]]; then
      err "forced managed target apply failed"
      return "$forced_rc"
    fi
    log "wallpaper set via forced managed override: $MANAGED_OVERRIDE_PATH"
    local forced_active
    forced_active="$(get_active_path_posix)"
    log "active wallpaper path: ${forced_active:-unknown}"
    stabilize_apply "$MANAGED_OVERRIDE_PATH" 2 || true
    if [[ "$MANAGED_JAMF_DEFAULT" -eq 1 ]]; then
      jamf_second_pass "$src" "$MANAGED_OVERRIDE_PATH" "$sudo_managed_copy"
    fi
    forced_active="$(get_active_path_posix)"
    log "active wallpaper path after stabilization: ${forced_active:-unknown}"
    if [[ "$watch" -eq 1 ]]; then
      start_watch_background "$input" "$interval" || return $?
    fi
    return $EXIT_OK
  fi

  if apply_unmanaged_with_verify "$src"; then
    log "wallpaper set via standard macOS APIs"
    if [[ "${WALLCTL_LAST_APPLY_UNVERIFIED:-0}" -eq 1 ]]; then
      log "warning: wallpaper applied but active-path verification was unavailable"
    fi
  else
    if [[ "$MANAGED_LOCKED" -eq 1 && -n "$MANAGED_OVERRIDE_PATH" ]]; then
      log "managed wallpaper policy detected; attempting managed override path"
      local managed_rc
      apply_managed_with_verify "$src" "$MANAGED_OVERRIDE_PATH" "$sudo_managed_copy"
      managed_rc=$?
      if [[ "$managed_rc" -ne 0 ]]; then
        err "unable to apply managed wallpaper override"
        err "run: wallctl doctor"
        if [[ "$sudo_managed_copy" -eq 0 ]]; then
          err "tip: retry with --sudo-managed-copy"
        fi
        return "$managed_rc"
      fi
      log "wallpaper set via managed override: $MANAGED_OVERRIDE_PATH"
      stabilize_apply "$MANAGED_OVERRIDE_PATH" 2 || true
      if [[ "$MANAGED_JAMF_DEFAULT" -eq 1 ]]; then
        jamf_second_pass "$src" "$MANAGED_OVERRIDE_PATH" "$sudo_managed_copy"
      fi
    else
      err "wallpaper apply verification failed"
      err "run: wallctl doctor"
      return $EXIT_APPLY_FAILED
    fi
  fi

  local active
  active="$(get_active_path_posix)"
  log "active wallpaper path: ${active:-unknown}"

  if [[ "$force_refresh" -eq 1 ]]; then
    refresh_wallpaper_services
    active="$(get_active_path_posix)"
    log "active wallpaper path after refresh: ${active:-unknown}"
  fi

  if [[ "$watch" -eq 1 ]]; then
    start_watch_background "$input" "$interval" || return $?
  fi

  return $EXIT_OK
}

cmd_watch() {
  local input=""
  local interval="15"

  while (( $# > 0 )); do
    case "$1" in
      --interval)
        shift
        [[ $# -gt 0 ]] || { err "--interval requires a value"; return $EXIT_USAGE; }
        interval="$1"
        ;;
      --quiet) QUIET=1 ;;
      -h|--help)
        print_help
        return $EXIT_OK
        ;;
      --*) err "unknown option: $1"; return $EXIT_USAGE ;;
      *)
        if [[ -z "$input" ]]; then
          input="$1"
        else
          err "unexpected extra argument: $1"
          return $EXIT_USAGE
        fi
        ;;
    esac
    shift
  done

  [[ -n "$input" ]] || { err "watch requires <file_or_dir>"; return $EXIT_USAGE; }
  [[ "$interval" =~ '^[0-9]+$' ]] || { err "interval must be a whole number"; return $EXIT_USAGE; }

  require_cmds osascript sips plutil shasum || return $EXIT_BLOCKED
  if ! ensure_state_dir; then
    err "cannot create state directory: $STATE_DIR"
    return $EXIT_BLOCKED
  fi

  log "watching wallpaper source: $input"
  log "interval: ${interval}s"

  while true; do
    local src
    src="$(resolve_input_image "$input")"
    if [[ -z "$src" ]]; then
      err "watch: unable to resolve image from input, retrying"
      sleep "$interval"
      continue
    fi

    local expected_active="$src"
    local must_apply=0

    managed_state

    if [[ "$MANAGED_LOCKED" -eq 1 && -n "$MANAGED_OVERRIDE_PATH" ]]; then
      expected_active="$MANAGED_OVERRIDE_PATH"
      local src_hash target_hash
      src_hash="$(shasum -a 256 "$src" | awk '{print $1}')"
      if [[ -f "$MANAGED_OVERRIDE_PATH" ]]; then
        target_hash="$(shasum -a 256 "$MANAGED_OVERRIDE_PATH" | awk '{print $1}')"
      else
        target_hash=""
      fi
      [[ "$src_hash" != "$target_hash" ]] && must_apply=1
    fi

    local active
    active="$(get_active_path_posix)"
    [[ "$active" != "$expected_active" ]] && must_apply=1

    if [[ "$must_apply" -eq 1 ]]; then
      log "[$(date '+%Y-%m-%d %H:%M:%S')] drift detected; re-applying"
      if ! cmd_set "$input" --quiet; then
        err "watch: re-apply failed"
      fi
    fi

    sleep "$interval"
  done
}

cmd_verify() {
  local as_json=0
  while (( $# > 0 )); do
    case "$1" in
      --json) as_json=1 ;;
      --quiet) QUIET=1 ;;
      -h|--help) print_help; return $EXIT_OK ;;
      --*) err "unknown option: $1"; return $EXIT_USAGE ;;
      *) err "unexpected argument: $1"; return $EXIT_USAGE ;;
    esac
    shift
  done

  managed_state

  local active
  active="$(get_active_path_posix)"

  local watcher_pid=""
  watcher_pid="$(watch_running_pid 2>/dev/null || true)"

  if [[ "$as_json" -eq 1 ]]; then
    printf '{'
    printf '"mode":"%s",' "$( [[ "$MANAGED_LOCKED" -eq 1 ]] && printf managed || printf unmanaged )"
    printf '"policy_plist":"%s",' "$(json_escape "$POLICY_PLIST")"
    printf '"managed_locked":%s,' "$( [[ "$MANAGED_LOCKED" -eq 1 ]] && printf true || printf false )"
    printf '"managed_override_path":"%s",' "$(json_escape "$MANAGED_OVERRIDE_PATH")"
    printf '"jamf_default_policy":%s,' "$( [[ "$MANAGED_JAMF_DEFAULT" -eq 1 ]] && printf true || printf false )"
    printf '"active_path":"%s",' "$(json_escape "$active")"
    printf '"watch_running":%s,' "$( [[ -n "$watcher_pid" ]] && printf true || printf false )"
    printf '"watch_pid":"%s"' "$(json_escape "$watcher_pid")"
    printf '}\n'
    return $EXIT_OK
  fi

  printf 'Mode: %s\n' "$( [[ "$MANAGED_LOCKED" -eq 1 ]] && printf managed || printf unmanaged )"
  printf 'Policy plist: %s\n' "$POLICY_PLIST"
  printf 'Managed locked: %s\n' "$( [[ "$MANAGED_LOCKED" -eq 1 ]] && printf true || printf false )"
  printf 'Managed override path: %s\n' "${MANAGED_OVERRIDE_PATH:-<none>}"
  printf 'Jamf default policy: %s\n' "$( [[ "$MANAGED_JAMF_DEFAULT" -eq 1 ]] && printf true || printf false )"
  printf 'Active wallpaper path: %s\n' "${active:-<unknown>}"
  if [[ -n "$watcher_pid" ]]; then
    printf 'Watch process: running (pid %s)\n' "$watcher_pid"
  else
    printf 'Watch process: not running\n'
  fi

  return $EXIT_OK
}

cmd_doctor() {
  local as_json=0
  while (( $# > 0 )); do
    case "$1" in
      --json) as_json=1 ;;
      --quiet) QUIET=1 ;;
      -h|--help) print_help; return $EXIT_OK ;;
      --*) err "unknown option: $1"; return $EXIT_USAGE ;;
      *) err "unexpected argument: $1"; return $EXIT_USAGE ;;
    esac
    shift
  done

  local blockers=()
  local warnings=()
  local checks=(osascript sips plutil shasum)

  local cmd
  for cmd in "$checks[@]"; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
      blockers+=("missing command: $cmd")
    fi
  done

  managed_state

  if [[ "$MANAGED_LOCKED" -eq 1 ]]; then
    if [[ -z "$MANAGED_OVERRIDE_PATH" ]]; then
      blockers+=("managed policy is locked but override-picture-path is missing")
    elif ! target_writable "$MANAGED_OVERRIDE_PATH"; then
      blockers+=("managed override path is not writable: $MANAGED_OVERRIDE_PATH")
    fi
    if [[ "$MANAGED_JAMF_DEFAULT" -eq 1 ]]; then
      warnings+=("jamf-managed default wallpaper detected; wallctl set will target the managed override path")
    fi
  fi

  local active
  active="$(get_active_path_posix)"
  if [[ -z "$active" ]]; then
    warnings+=("could not read active wallpaper path (Automation/TCC may block Finder/System Events)")
  fi

  if [[ "$as_json" -eq 1 ]]; then
    printf '{'
    printf '"ok":%s,' "$( (( ${#blockers[@]} == 0 )) && printf true || printf false )"
    printf '"mode":"%s",' "$( [[ "$MANAGED_LOCKED" -eq 1 ]] && printf managed || printf unmanaged )"
    printf '"policy_plist":"%s",' "$(json_escape "$POLICY_PLIST")"
    printf '"managed_locked":%s,' "$( [[ "$MANAGED_LOCKED" -eq 1 ]] && printf true || printf false )"
    printf '"managed_override_path":"%s",' "$(json_escape "$MANAGED_OVERRIDE_PATH")"
    printf '"jamf_default_policy":%s,' "$( [[ "$MANAGED_JAMF_DEFAULT" -eq 1 ]] && printf true || printf false )"
    printf '"active_path":"%s",' "$(json_escape "$active")"
    printf '"blockers":[
'
    local i
    for (( i=1; i<=${#blockers[@]}; i++ )); do
      printf '"%s"' "$(json_escape "${blockers[$i]}")"
      [[ "$i" -lt "${#blockers[@]}" ]] && printf ','
    done
    printf '],"warnings":[
'
    for (( i=1; i<=${#warnings[@]}; i++ )); do
      printf '"%s"' "$(json_escape "${warnings[$i]}")"
      [[ "$i" -lt "${#warnings[@]}" ]] && printf ','
    done
    printf ']}\n'
  else
    printf 'Doctor mode: %s\n' "$( (( ${#blockers[@]} == 0 )) && printf OK || printf BLOCKED )"
    printf 'Detected mode: %s\n' "$( [[ "$MANAGED_LOCKED" -eq 1 ]] && printf managed || printf unmanaged )"
    printf 'Policy plist: %s\n' "$POLICY_PLIST"
    printf 'Managed override path: %s\n' "${MANAGED_OVERRIDE_PATH:-<none>}"
    printf 'Active wallpaper path: %s\n' "${active:-<unknown>}"

    if (( ${#blockers[@]} > 0 )); then
      printf '\nBlockers:\n'
      local b
      for b in "$blockers[@]"; do
        printf '  - %s\n' "$b"
      done
    fi

    if (( ${#warnings[@]} > 0 )); then
      printf '\nWarnings:\n'
      local w
      for w in "$warnings[@]"; do
        printf '  - %s\n' "$w"
      done
    fi
  fi

  if (( ${#blockers[@]} > 0 )); then
    return $EXIT_BLOCKED
  fi
  return $EXIT_OK
}

cmd_restore() {
  local restore_path=""
  local use_latest=0

  while (( $# > 0 )); do
    case "$1" in
      --latest) use_latest=1 ;;
      --path)
        shift
        [[ $# -gt 0 ]] || { err "--path requires a value"; return $EXIT_USAGE; }
        restore_path="$1"
        ;;
      --quiet) QUIET=1 ;;
      -h|--help) print_help; return $EXIT_OK ;;
      --*) err "unknown option: $1"; return $EXIT_USAGE ;;
      *) err "unexpected argument: $1"; return $EXIT_USAGE ;;
    esac
    shift
  done

  if [[ "$use_latest" -eq 1 && -n "$restore_path" ]]; then
    err "use either --latest or --path, not both"
    return $EXIT_USAGE
  fi

  if [[ "$use_latest" -eq 1 || -z "$restore_path" ]]; then
    restore_path="$(latest_backup_path 2>/dev/null || true)"
    [[ -n "$restore_path" ]] || { err "no backup found in $BACKUP_DIR"; return $EXIT_USAGE; }
  fi

  [[ -f "$restore_path" ]] || { err "backup file not found: $restore_path"; return $EXIT_USAGE; }

  log "restoring wallpaper from backup: $restore_path"
  cmd_set "$restore_path" --quiet
  local rc=$?
  if [[ "$rc" -eq 0 ]]; then
    log "restore complete"
  fi
  return "$rc"
}

main() {
  if [[ $# -eq 0 ]]; then
    cmd_interactive
    return $?
  fi

  local cmd="${1:-help}"
  shift 2>/dev/null || true

  case "$cmd" in
    set) cmd_set "$@" ;;
    watch) cmd_watch "$@" ;;
    verify) cmd_verify "$@" ;;
    doctor) cmd_doctor "$@" ;;
    restore) cmd_restore "$@" ;;
    stop-watch) stop_watch ;;
    version) printf '%s\n' "$VERSION" ;;
    help|-h|--help) print_help ;;
    *)
      err "unknown command: $cmd"
      print_help >&2
      return $EXIT_USAGE
      ;;
  esac
}

main "$@"
